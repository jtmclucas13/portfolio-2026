---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Flex from "../../components/Flex.astro";
import ImageWithCaption from "../../components/ImageWithCaption.astro";
import { Fragment } from "astro/jsx-runtime";

const allTheaterEntries = (await getCollection("theater")).sort(
  (a, b) =>
    new Date(b.data.premiereDate).getTime() -
    new Date(a.data.premiereDate).getTime(),
);
---

<script>
  function isHTMLElement(element: Element | null) {
    return !!element && element instanceof HTMLElement;
  }

  function showItem(element: Element) {
    if (!isHTMLElement(element)) {
      return;
    }

    element.style.display = "block";
  }

  function hideItem(element: Element) {
    if (!isHTMLElement(element)) {
      return;
    }

    element.style.display = "none";
  }

  const radioButtons = document.querySelectorAll('input[name="filter"]');

  radioButtons.forEach((radio) => {
    radio.addEventListener("change", (event) => {
      const target = event.target as HTMLInputElement;

      if (target.checked) {
        const newValue = target.value;
        const directingItems = document.querySelectorAll(
          '[data-type="directing"]',
        );
        const actingItems = document.querySelectorAll('[data-type="acting"]');

        document.startViewTransition(() => {
          if (newValue === "all") {
            [...directingItems, ...actingItems].forEach(showItem);
          } else if (newValue === "directing") {
            actingItems.forEach(hideItem);
            directingItems.forEach(showItem);
          } else if (newValue === "acting") {
            directingItems.forEach(hideItem);
            actingItems.forEach(showItem);
          }
        });
      }
    });
  });
</script>

<Layout>
  <div class="content">
    <header>
      <h2>Theater Experience (most recent first)</h2>
      <div class="radio-filters">
        <div>
          <label
            ><input checked name="filter" type="radio" value="all" />All<span
              class="radio-button"></span></label
          >
          <label
            ><input name="filter" type="radio" value="acting" />Acting<span
              class="radio-button"></span></label
          >
          <label
            ><input
              name="filter"
              type="radio"
              value="directing"
            />Directing<span class="radio-button"></span></label
          >
        </div>
      </div>
    </header>
    {
      allTheaterEntries.map((entry, index) => (
        <div data-type={entry.data.role === null ? "directing" : "acting"}>
          <Flex direction={index % 2 === 0 ? "row" : "row-reverse"} gap={2}>
            {entry.data.photos.length > 0 && (
              <div class="image">
                <ImageWithCaption
                  alt={entry.data.title}
                  caption={
                    entry.data.photos[0]!.photographer
                      ? `Photo Credit: ${entry.data.photos[0]?.photographer}`
                      : ""
                  }
                  src={entry.data.photos[0]!.image}
                />
              </div>
            )}
            <Flex class="entry-content" direction="column" gap={2}>
              <Flex direction="column" gap={0.25}>
                <h4>{entry.data.title}</h4>
                <h5>By {entry.data.by}</h5>
                <h5>Directed by {entry.data.directedBy}</h5>
                <h5>{entry.data.theater}</h5>
              </Flex>
              {entry.data.blurbs.map((blurb) => (
                <blockquote cite={blurb.link}>
                  <a
                    href={blurb.link}
                    rel="noopener noreferrer"
                    target="_blank"
                  >
                    {blurb.quote}
                  </a>
                  <footer>
                    <cite>{blurb.author}</cite>
                  </footer>
                </blockquote>
              ))}
            </Flex>
          </Flex>
          <hr />
        </div>
      ))
    }
  </div>
</Layout>

<style>
  .content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 2rem;
  }

  header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .radio-filters {
    border-image-outset: 34px;
    border: 20px solid transparent;
    border-image: url("../../assets/lace-border.png") 34 round;
    flex: 1 1 50%;
    text-align: center;

    > div {
      background-color: var(--color-black);
      display: flex;
      gap: 2rem;
      height: 100%;
      justify-content: center;
      padding: 1rem;
      width: 100%;
    }
  }

  label {
    align-items: center;
    color: var(--color-white);
    cursor: pointer;
    display: flex;
    font-size: 1.25rem;
    position: relative;
    padding-left: 35px;

    &:hover {
      input {
        ~ .radio-button {
          border-color: var(--color-primary);
          transition: border-color 250ms ease-in;
        }
      }
    }
  }

  input {
    cursor: pointer;
    height: 0;
    opacity: 0;
    position: absolute;
    width: 0;

    &:checked {
      ~ .radio-button {
        background-color: var(--color-primary);
        border-color: var(--color-primary);

        &:after {
          display: block;
        }
      }
    }
  }

  .radio-button {
    background-color: var(--color-white);
    border: 1px solid var(--color-black);
    border-radius: 50%;
    height: 25px;
    left: 0;
    position: absolute;
    top: 0;
    transition: border-color 250ms ease-in;
    width: 25px;

    &:after {
      background: var(--color-white);
      border-radius: 50%;
      content: "";
      display: none;
      height: 9px;
      left: 7px;
      position: absolute;
      top: 7px;
      width: 9px;
    }
  }

  h4 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  blockquote {
    border-left: 3px solid var(--color-primary);
    padding-left: 1.5rem;
    font-size: 1.1rem;
    margin: 0;

    a {
      cursor: pointer;

      &:hover {
        text-decoration: underline;
      }
    }

    cite {
      font-size: 1rem;

      &::before {
        content: "— ";
      }
    }

    footer {
      padding-top: 1rem;
    }
  }

  .entry-content {
    flex: 2;
  }

  .image {
    flex: 3;
  }

  hr {
    background-color: var(--color-black);
    border: none;
    height: 1px;
    margin: 2rem 0;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
  }

  @keyframes fade-out {
    to {
      opacity: 0;
    }
  }
</style>
