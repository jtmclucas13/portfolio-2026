---
import { Font } from "astro:assets";
const { title = "Joshua McLucas - Career Chameleon" } = Astro.props;
---

<meta name="generator" content={Astro.generator} />
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />

<title>{title}</title>
<meta
  name="description"
  content="The web home of Philadelphia-based multi-hyphenate, Joshua McLucas."
/>

<link rel="icon" href="/favicon.ico" />
<link rel="icon" type="image/png" href="/favicon.png" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Outfit:wght@300&family=Tangerine&family=Zen+Dots&display=swap"
  rel="stylesheet"
/>
<Font cssVariable="--font-icon" preload />

<style is:global>
  :root {
    --color-white: #fcf7f8;
    --color-black: #29373d;
    --color-tertiary: #dcd9f4;
    --color-secondary: #fabb00;
    --color-primary: #8ca691;
    --font-display: "Zen Dots", sans-serif;
    --font-cursive: "Tangerine", cursive;
    --font-body: "Outfit", sans-serif;

    font-size: 16px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-size: 100%;
  }

  p {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-optical-sizing: auto;
    margin: 0;
    margin-bottom: 1rem;

    &:last-child {
      margin-bottom: 0;
    }
  }

  h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    margin: 0;
  }

  h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin: 0;
  }
</style>
