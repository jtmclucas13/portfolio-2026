---
import { Font } from "astro:assets";
const { title = "Joshua McLucas - Career Chameleon" } = Astro.props;
---

<meta name="generator" content={Astro.generator} />
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />

<title>{title}</title>
<meta
  name="description"
  content="The web home of Philadelphia-based multi-hyphenate, Joshua McLucas."
/>

<link rel="icon" href="/favicon.ico" />
<link rel="icon" type="image/png" href="/favicon.png" />

<Font cssVariable="--font-icon" preload />
<Font cssVariable="--font-display" preload />
<Font cssVariable="--font-cursive" preload />
<Font cssVariable="--font-body" preload />

<style is:global>
  :root {
    --color-white: #fcf7f8;
    --color-black: #29373d;
    --color-tertiary: #dcd9f4;
    --color-secondary: #fabb00;
    --color-primary: #8ca691;
    --color-danger: #ab0505;
    --radius-base: 12px;

    font-size: 16px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-body);
    font-size: 100%;
  }

  input,
  textarea {
    border-radius: var(--radius-base);
    border: 1px solid var(--color-black);
    font-family: var(--font-body);
    padding: 0.5rem;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul {
    margin-block-start: 0;
    margin-block-end: 0;
    padding-inline-start: 0;
  }

  li {
    list-style-type: none;
  }

  p {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-optical-sizing: auto;
    margin: 0;
    margin-bottom: 1rem;

    &:last-child {
      margin-bottom: 0;
    }
  }

  h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    margin: 0;
  }

  h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin: 0;
  }

  h3 {
    font-family: var(--font-display);
    font-size: 1.33rem;
    margin: 0;
  }
</style>
