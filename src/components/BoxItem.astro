---
interface Props {
  class?: string;
  href?: string;
  icon?: string; /* actually needs to be a bundled glyph name from the config, but no better type exists */
  subtitle: string;
  theme?: "danger" | "success";
  title: string;
}
const { class: className, href, icon, subtitle, theme, title } = Astro.props;

const Element = href ? "a" : "div";
---

<Element class:list={["box", { link: !!href }, theme, className]} href={href}>
  {
    Astro.slots.has("default") && (
      <div class="image">
        <slot />
      </div>
    )
  }
  <div class="main-content">
    <span class="title">{icon && <span class="icon">{icon}</span>}{title}</span>
    <span class="subtitle">{subtitle}</span>
  </div>
</Element>

<style>
  .box {
    background-color: var(--color-tertiary);
    border-radius: var(--radius-base);
    border: 3px solid var(--color-black);
    box-shadow: 6px 6px 0 var(--color-black);
    color: var(--color-black);
    display: flex;
    gap: 16px;
    padding: 1.25rem;

    &.link {
      cursor: pointer;
      text-align: left;
      transition: background-color 0.2s ease-in-out;

      &:hover {
        background-color: var(--color-secondary);
      }
    }
  }

  .main-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .icon {
    font-family: var(--font-icon);
    font-size: 1.5rem;
  }

  .title {
    align-items: center;
    display: flex;
    color: var(--color-black);
    font-family: var(--font-display);
    font-size: 1.1rem;
    gap: 4px;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: 1rem;
  }

  .danger {
    background-color: var(--color-danger);
    color: var(--color-white);

    .title {
      color: var(--color-white);
    }
  }

  .success {
    background-color: var(--color-primary);
  }
</style>
