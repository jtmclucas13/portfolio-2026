---
import Head from "../components/Head.astro";
import Header from "../components/Header.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <Head />
  </head>
  <body>
    <Header />
    <div class="content">
      <slot />
    </div>
    <footer>® Joshua McLucas, {new Date().getFullYear()}</footer>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
  body {
    background-color: var(--color-tertiary);
  }

  .content {
    display: flex;
    flex-direction: column;
  }

  footer {
    background-color: var(--color-black);
    color: var(--color-secondary);
    font-family: var(--font-display);
    font-size: 1.25rem;
    padding: 2rem;
  }
</style>
